{
  "name": "contextqmd-mcp",
  "version": "0.2.9",
  "description": "MCP server for local-first, version-aware library documentation via ContextQMD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/contextqmd/contextqmd-mcp.git"
  },
  "keywords": [
    "mcp",
    "documentation",
    "docs",
    "context",
    "contextqmd",
    "qmd",
    "library",
    "ai",
    "model-context-protocol",
    "search",
    "local-first"
  ],
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "contextqmd-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "node -e \"const fs=require('fs');const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!')){fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c)}\"",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@tobilu/qmd": "^2.0.1",
    "commander": "^14.0.0",
    "express": "^5.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
